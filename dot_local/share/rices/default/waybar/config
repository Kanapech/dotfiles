{
	"layer": "top", 
	"position": "top", 
	"margin-top": 1,
	"height": 20,
	"spacing" : 8,
	"modules-left": ["hyprland/workspaces", "group/hardware", "hyprland/window"],
	"modules-center": ["clock"],
	"modules-right": [
		"tray", 
		"backlight", 
		"power-profiles-daemon", 
		"pulseaudio", 
		"network", 
		"battery", 
		"hyprland/language", 
		"custom/notification"
	],
	"reload_style_on_change":true,

	"hyprland/window": {
		"max-length": 30,
		"tooltip": false,
		"format": "{title}",
		"separate-outputs": true,
		"icon": true,
		"icon-size": 14,
		"rewrite": {
			"(.*) - Mozilla Firefox": "ЁЯМО $1",
			"(.*) - zsh": "> [$1]"
		}
	},

	"hyprland/workspaces": {
    	"all-outputs": false,
	    "active-only": false,
		"format": "{icon}",
		"format-icons": {
			"1": "яТк",
			"2": "яТк",
			"3": "яТк",
			"4": "яТк",
			"5": "яТк",
			"active": "яЖТ",
			"default": "яТк" 
		},
		"persistent-workspaces": {
		    "DP-1": [1, 2, 3, 4, 5],
		    "DP-2": [6, 7, 8, 9, 10]
		}
	},

	"hyprland/language": {
	    "format": "{}",
	    "format-en": "us",
	    "format-fr": "fr",
	    "keyboard-name": "2.4g-dongle"
	},

	"wlr/taskbar": {
	    "sort-by-app-id": true,
	    "format": "{icon}",
	    "icon-size": 20,
	    "icon-theme": "Papirus-Dark",
	    "tooltip-format": "{title}",
	    "on-click": "activate",
	    "on-click-middle": "close",
	    "ignore-list": [
	       "btop"
	    ],
	    "rewrite": {
	        "Firefox Web Browser": "Firefox",
	        "Kitty": "Terminal",
	        ".*(steam_app_[0-9]+).*": "Game"
	    }
	},

	"clock": {
	      "format": "{:%H:%M}",
	      "interval":1,
	      "tooltip-format": "\n<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
	      "calendar-weeks-pos": "right",
	      "today-format": "<span color='#7645AD'><b><u>{}</u></b></span>",
	      "format-calendar": "<span color='#aeaeae'><b>{}</b></span>",
	      "format-calendar-weeks": "<span color='#aeaeae'><b>W{:%V}</b></span>",
	      "format-calendar-weekdays": "<span color='#aeaeae'><b>{}</b></span>"
	},

	"bluetooth": {
		"format-on": "яКУ",
		"format-off": "",
		"format-disabled": "ґ░В▓",
		"format-connected": "ґ░В┤",
		"format-connected-battery": "{device_battery_percentage}% ґ░В┤",
		"tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
		"on-click": "rofi-bluetooth",
 	},

	"power-profiles-daemon": {
		"format": "{icon}",
		"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
		"tooltip": true,
		"format-icons": {
			 "default": "яГз",
			 "performance": "яГз",
			 "balanced": "яЙО",
			 "power-saver": "яБм"
		}
	},

	"network": {
		"interface": "enp12s0",
		"format-wifi": "яЗл ",
		"format-ethernet":"ґ░ИА",
		"format-disconnected": "юмБ",
		"tooltip-format": "{ipaddr}",
		"tooltip-format-wifi": "{essid} ({signalStrength}%) яЗл | {ipaddr}",
		"tooltip-format-ethernet": "{ifname} ЁЯЦз | {ipaddr}",
		"on-click": "networkmanager_dmenu"
	},

	"battery": {
		"interval":1,
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 20
		},
		"format": "{capacity}%  {icon} ",
		"format-charging": "{capacity}% ґ░ВД ",
		"format-plugged": "{capacity}% ґ░ВД юмн",
		"format-alt": "{time} {icon}",
		"format-icons": [
			"ґ░Б╗",
			"ґ░Б╝",
			"ґ░Б╛",
			"ґ░ВА",
			"ґ░ВВ",
			"ґ░Б╣"
		],
	},
    
	"backlight": {
		"device": "intel_backlight",
		"format": "<span font='12'>{icon}</span>",
		"format-icons": [
			"юПХ",
			"юПЦ",
			"юПЧ",
			"юПШ",
			"юПЪ",
			"юПЫ",
			"юПЬ",
			"юПЭ",
			"юПЮ",
			"юПЯ"
		],
		"on-scroll-down": "light -A 10",
		"on-scroll-up": "light -U 10",
		"smooth-scrolling-threshold": 1
	},

	"group/hardware": {
		"orientation": "inherit",
		"modules": [
			"cpu",
			"memory",
			"temperature"
		]
	},

	"cpu": {
		"interval": 1,
		"format": "ю║Ь  {usage}%",
		"min-length": 6,
		"max-length": 6,
		"format-icons": ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ"],
		"on-click": "kitty --class kitty-btop btop"
	},

	"memory": {
		"format": "юЙж  {percentage}%",
		"on-click": "kitty --class kitty-btop btop"
	},

	"temperature": {
		"tooltip": false,
		"hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
		"format": "яЛЙ {temperatureC}┬░C",            
		"format-critical": "яЛЗ {temperatureC}┬░C",
		"interval": 3,
		"critical-threshold": 80,
		"on-click": "kitty --class kitty-btop btop"
	},

	"pulseaudio": {
		"format": "{icon} {volume} %",
		"format-bluetooth":"ґ░В░",
		"format-muted": "<span font='12'>юмд</span>",
		"format-icons": {
			"headphones": "яАе",
			"bluetooth": "ґ░е░",
			"handsfree": "яАе",
			"headset": "ґ▒бм",
			"phone": "яВХ",
			"portable": "яВХ",
			"car": "яЖ╣",
			"default": ["ЁЯХи","ЁЯХй","ЁЯХк"]
		},
		"on-click": "amixer sset Master toggle",
		"on-click-right": "pavucontrol",
		"tooltip-format": "{icon} {volume}%"
	},

	"jack": {
	    "format": "{} ґ▒ОФ ",
	    "format-xrun": "{xruns} xruns",
	    "format-disconnected": "DSP off",
	    "realtime": true
	},

	"tray": {
	    "icon-size": 20,
	    "spacing": 10
	},

	"upower": {
	    "show-icon": false,
	    "hide-if-empty": true,
	    "tooltip": true,
	    "tooltip-spacing": 20
	},

	"custom/powerDraw": {
		"format": "{}",
		"interval": 1,
		"exec": "~/.local/share/rices/default/waybar/scripts/powerdraw.sh",
		"return-type": "json"
	},

	"custom/notification": {
	    "tooltip": false,
	    "format": "{icon} ",
	    "format-icons": {
	        "notification": "ґ▒Ел",
	        "none": "яГ│",
	        "dnd-notification": "яЗ╢",
	        "dnd-none": "ґ░ВЫ",
	        "inhibited-notification": "яВв",
	        "inhibited-none": "яВв",
	        "dnd-inhibited-notification": "яЗ╖",
	        "dnd-inhibited-none": "яЗ╖"
	    },
	    "return-type": "json",
	    "exec-if": "which swaync-client",
	    "exec": "swaync-client -swb",
	    "on-click": "sleep 0.1 && swaync-client -t -sw",
	    "on-click-right": "sleep 0.1 && swaync-client -d -sw",
	    "escape": true
	}
}
