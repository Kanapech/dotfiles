{
  "layer": "top", "position": "top",
  "modules-left": ["hyprland/window",  "wlr/taskbar", "memory", "cpu", "temperature", "custom/powerDraw" ],
  "modules-center": ["clock", "hyprland/workspaces"],
  "modules-right": ["tray", "backlight", "bluetooth", "power-profiles-daemon", "gamemode", "pulseaudio", "network", "battery" ],
  "reload_style_on_change":true,

"hyprland/workspaces": {
    "all-outputs": false,
    "active-only": false,
	"format": "{icon}",
	"format-icons": {
		"1": "пТ™",
		"2": "пТ™",
		"3": "пТ™",
		"4": "пТ™",
		"5": "пТ™",
		"6": "пТ™",
		"active": "пЖТ",
		"default": "пДС" 
	}
},

"wlr/taskbar": {
    "sort-by-app-id": true,
    "format": "{icon}",
    "icon-size": 20,
    "icon-theme": "Papirus-Dark",
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
       "btop"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
        "Firefox Web Browser": "Firefox",
        "Kitty": "Terminal",
        ".*(steam_app_[0-9]+).*": "Game"

    }
},

"clock": {
      "format": "{:%H:%M}",
      "interval":1,
      "tooltip-format": "\n<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "calendar-weeks-pos": "right",
      "today-format": "<span color='#7645AD'><b><u>{}</u></b></span>",
      "format-calendar": "<span color='#aeaeae'><b>{}</b></span>",
      "format-calendar-weeks": "<span color='#aeaeae'><b>W{:%V}</b></span>",
      "format-calendar-weekdays": "<span color='#aeaeae'><b>{}</b></span>"
      },

  "bluetooth": {
  "format-on": "пКУ",
  "format-off": "",
  "format-disabled": "у∞В≤",
  "format-connected": "у∞Ві",
  "format-connected-battery": "{device_battery_percentage}% у∞Ві",
  "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
  "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
  "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
  "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
  "on-click": "rofi-bluetooth",
 },

 "power-profiles-daemon": {
   "format": "{icon}",
   "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
   "tooltip": true,
   "format-icons": {
     "default": "пГІ",
     "performance": "пГІ",
     "balanced": "пЙО",
     "power-saver": "пБђ"
   }
 },

 "gamemode": {
      "format": "{glyph}",
      "format-alt": "{glyph} {count}",
      "glyph": "пЮ≥",
      "hide-not-running": true,
      "use-icon": true,
      "icon-name": "input-gaming-symbolic",
      "icon-spacing": 4,
      "icon-size": 20,
      "tooltip": true,
      "tooltip-format": "Games running: {count}"
}, 

"network": {
      "format-wifi": "пЗЂ ",
      "format-ethernet":"оЉЙ ",
      "format-disconnected": "ођБ",
      "tooltip-format": "{ipaddr}",
      "tooltip-format-wifi": "{essid} ({signalStrength}%) пЗЂ | {ipaddr}",
      "tooltip-format-ethernet": "{ifname} рЯЦІ | {ipaddr}",
      "on-click": "networkmanager_dmenu"
    },

"battery": {
    "interval":1,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}%  {icon} ",
        "format-charging": "{capacity}% у∞ВД ",
        "format-plugged": "{capacity}% у∞ВД ођ≠",
        "format-alt": "{time} {icon}",
            "format-icons": [
          "у∞Бї",
          "у∞БЉ",
          "у∞БЊ",
          "у∞ВА",
          "у∞ВВ",
          "у∞Бє"
        ],
    },
"backlight": {
  "device": "intel_backlight",
  "format": "<span font='12'>{icon}</span>",
  "format-icons": [
    "оПХ",
    "оПЦ",
    "оПЧ",
    "оПШ",
    "оПЪ",
    "оПЫ",
    "оПЬ",
    "оПЭ",
    "оПЮ",
    "оПЯ",
  ],
  "on-scroll-down": "light -A 10",
  "on-scroll-up": "light -U 10",
  "smooth-scrolling-threshold": 1
  },

 "disk": {
    "interval": 30,
    "format": "пЗА  {percentage_used}%",
    "path": "/",
    "on-click": "kitty --class kitty-btop btop"
  },

  "cpu": {
      "interval": 1,
      "format": "оЇЬ  {usage}%",
      "min-length": 6,
      "max-length": 6,
      "format-icons": ["вЦБ", "вЦВ", "вЦГ", "вЦД", "вЦЕ", "вЦЖ", "вЦЗ", "вЦИ"],
      "on-click": "kitty --class kitty-btop btop"
 },

"memory": {
  "format": "оЙ¶  {percentage}%",
  "on-click": "kitty --class kitty-btop btop"
},

"hyprland/window": {
    "tooltip": false,
    "format": "- {initialTitle} -",
    "separate-outputs": true,
    "icon": true,
    "icon-size": 14,
    "rewrite": {
         "(.*) - Mozilla Firefox": "рЯМО $1",
         "(.*) - zsh": "> [$1]"
    }
},

"temperature": {
  "tooltip": false,
  "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
  "format": "пЛЙ {temperatureC}¬∞C",            
  "format-critical": "пЛЗ {temperatureC}¬∞C",
  "interval": 3,
  "critical-threshold": 80,
  "on-click": "kitty --class kitty-btop btop"
 },

"pulseaudio": {
  "format": "{volume}% {icon}",
  "format-bluetooth":"у∞В∞",
  "format-muted": "<span font='12'>ођ§</span>",
  "format-icons": {
    "headphones": "пА•",
    "bluetooth": "у∞•∞",
    "handsfree": "пА•",
    "headset": "у±°ђ",
    "phone": "пВХ",
    "portable": "пВХ",
    "car": "пЖє",
    "default": ["рЯХ®","рЯХ©","рЯХ™"]
  },
  "justify": "center",
  "on-click": "amixer sset Master toggle",
  "on-click-right": "pavucontrol",
  "tooltip-format": "{icon}  {volume}%"
},

"jack": {
    "format": "{} у±ОФ",
    "format-xrun": "{xruns} xruns",
    "format-disconnected": "DSP off",
    "realtime": true
},

"tray": {
    "icon-size": 20,
    "spacing": 10
},

"upower": {
    "show-icon": false,
    "hide-if-empty": true,
    "tooltip": true,
    "tooltip-spacing": 20
},

  "custom/powerDraw": {
    "format": "{}",
    "interval": 1,
    "exec": "~/.config/waybar/scripts/powerdraw.sh",
    "return-type": "json"
  }

}

