{
	"hyprland/window": {
		"max-length": 30,
		"tooltip": false,
		"format": "{title}",
		"separate-outputs": true,
		"icon": true,
		"icon-size": 14,
		"rewrite": {
			"(.*) - Mozilla Firefox": "ΏθΝΟ $1",
			"(.*) - zsh": "> [$1]"
		}
	},

	"hyprland/workspaces": {
    	"all-outputs": false,
	    "active-only": false,
		"format": "{icon}",
		"format-icons": {
			"1": "ΎΤς",
			"2": "ΎΤς",
			"3": "ΎΤς",
			"4": "ΎΤς",
			"5": "ΎΤς",
			"active": "ΎΗΤ",
			"default": "ΎΤς" 
		},
		"persistent-workspaces": {
		    "DP-1": [1, 2, 3, 4, 5],
		    "DP-2": [6, 7, 8, 9, 10]
		}
	},

	"group/keyboard": {
		"orientation": "inherit",
		"modules": [
			"hyprland/language",
			"keyboard-state"
		]
	},

	"hyprland/language": {
		"on-click": "hyprctl switchxkblayout '2.4g-dongle' next",
	    "on-scroll-up": "hyprctl switchxkblayout '2.4g-dongle' next",
        "on-scroll-down": "hyprctl switchxkblayout '2.4g-dongle' prev",
	    "format": "ΎΕε   {}",
	    "format-en": "us",
	    "format-fr": "fr",
	    "keyboard-name": "2.4g-dongle"
	},

	"keyboard-state": {
	    "capslock": true,
	    "format": "{icon}",
	    "format-icons": {
	        "locked": "ΎΑμ",
	        "unlocked": "ΎΓε"
	    }
	},

	"wlr/taskbar": {
	    "sort-by-app-id": true,
	    "format": "{icon}",
	    "icon-size": 20,
	    "icon-theme": "Papirus-Dark",
	    "tooltip-format": "{title}",
	    "on-click": "activate",
	    "on-click-middle": "close",
	    "ignore-list": [
	       "btop"
	    ],
	    "rewrite": {
	        "Firefox Web Browser": "Firefox",
	        "Kitty": "Terminal",
	        ".*(steam_app_[0-9]+).*": "Game"
	    }
	},

	"clock": {
	      "format": "ΎΑΩ   {:%H:%M}",
	      "interval":1,
	      "tooltip-format": "\n<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
	      "calendar-weeks-pos": "right",
	      "today-format": "<span color='#7645AD'><b><u>{}</u></b></span>",
	      "format-calendar": "<span color='#aeaeae'><b>{}</b></span>",
	      "format-calendar-weeks": "<span color='#aeaeae'><b>W{:%V}</b></span>",
	      "format-calendar-weekdays": "<span color='#aeaeae'><b>{}</b></span>"
	},

	"custom/ScrollMPRIS": {
	    "return-type": "json",
	    "exec": "ScrollMPRIS --format '{title} - {album} - {artist}' -s 50 -w 40 --scroll reset --freeze",
	    "escape": true,
	    "on-click": "playerctl play-pause"
	},

	"group/performance": {
		"orientation": "inherit",
		"modules": [
			"power-profiles-daemon",
			"gamemode"
		]
	},

	"power-profiles-daemon": {
		"format": "{icon}",
		"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
		"tooltip": true,
		"format-icons": {
			 "default": "ΎΔπ",
			 "performance": "ΎΔπ",
			 "balanced": "ΎΚΟ",
			 "power-saver": "ΎΒυ"
		}
	},

	"gamemode": {
	    "format": "{glyph}",
	    "format-alt": "{glyph} {count}",
	    "glyph": "Ύη│",
	    "hide-not-running": false,
	    "use-icon": true,
	    "icon-name": "input-gaming-symbolic",
	    "icon-spacing": 0,
	    "icon-size": 20,
	    "tooltip": true,
	    "tooltip-format": "Games running: {count}"
	},

	"group/networking": {
		"orientation": "inherit",
		"modules": [
			"network",
			"bluetooth"
		]
	},

	"bluetooth": {
		"format-on": "ΎΛΥ",
		"format-off": "",
		"format-disabled": "≤░Γ▓",
		"format-connected": "≤░Γ┤",
		"format-connected-battery": "{device_battery_percentage}% ≤░Γ┤",
		"tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
		"on-click": "rofi-bluetooth",
 	},

	"network": {
		"interface": "enp12s0",
		"format-wifi": "ΎΘτ ",
		"format-ethernet": "≤░ΙΑ",
		"format-disconnected": "ΌυΒ",
		"tooltip-format": "{ipaddr}",
		"tooltip-format-wifi": "{essid} ({signalStrength}%) ΎΘτ | {ipaddr}",
		"tooltip-format-ethernet": "{ifname} ΏθΨπ | {ipaddr}",
		"on-click": "networkmanager_dmenu"
	},

	"battery": {
		"interval":1,
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 20
		},
		"format": "{capacity}%  {icon}",
		"format-charging": "{capacity}% ≤░ΓΕ",
		"format-plugged": "{capacity}% ≤░ΓΕ Όυφ",
		"format-alt": "{time} {icon}",
		"format-icons": [
			"≤░Β╗",
			"≤░Β╝",
			"≤░Β╛",
			"≤░ΓΑ",
			"≤░ΓΓ",
			"≤░Β╣"
		],
	},
    
	"backlight": {
		"device": "intel_backlight",
		"format": "<span font='12'>{icon}</span>",
		"format-icons": [
			"ΌΠΧ",
			"ΌΠΨ",
			"ΌΠΩ",
			"ΌΠα",
			"ΌΠγ",
			"ΌΠδ",
			"ΌΠε",
			"ΌΠζ",
			"ΌΠη",
			"ΌΠθ"
		],
		"on-scroll-down": "light -A 10",
		"on-scroll-up": "light -U 10",
		"smooth-scrolling-threshold": 1
	},

	"group/hardware": {
		"orientation": "inherit",
		"modules": [
			"cpu",
			"memory",
			"temperature"
		]
	},

	"cpu": {
		"interval": 1,
		"format": "Ό║ε  {usage}%",
		"min-length": 6,
		"max-length": 6,
		"format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"],
		"on-click": "kitty --class kitty-btop btop"
	},

	"memory": {
		"format": "ΌΚο  {percentage}%",
		"on-click": "kitty --class kitty-btop btop"
	},

	"temperature": {
		"tooltip": false,
		"hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
		"format": "ΎΜΚ {temperatureC}┬░C",            
		"format-critical": "ΎΜΘ {temperatureC}┬░C",
		"interval": 3,
		"critical-threshold": 80,
		"on-click": "kitty --class kitty-btop btop"
	},

	"pulseaudio": {
		"format": "{icon}   {volume}%",
		"format-bluetooth":"≤░Γ░",
		"format-muted": "<span font='12'>Όυν</span>",
		"format-icons": {
			"headphones": "ΎΑξ",
			"bluetooth": "≤░ξ░",
			"handsfree": "ΎΑξ",
			"headset": "≤▒κυ",
			"phone": "ΎΓΧ",
			"portable": "ΎΓΧ",
			"car": "ΎΗ╣",
			"default": ["ΎΑο","ΎΑπ","ΎΑρ"]
		},
		"on-click": "amixer sset Master toggle",
		"on-click-right": "pavucontrol",
		"tooltip-format": "{icon}   {volume}%"
	},

	"jack": {
	    "format": "{} ≤▒ΟΦ ",
	    "format-xrun": "{xruns} xruns",
	    "format-disconnected": "DSP off",
	    "realtime": true
	},

	"tray": {
	    "icon-size": 20,
	    "spacing": 10
	},

	"custom/powerDraw": {
		"format": "{}",
		"interval": 1,
		"exec": "~/.local/share/rices/default/waybar/scripts/powerdraw.sh",
		"return-type": "json"
	},

	"custom/notification": {
	    "tooltip": false,
	    "format": "{icon}",
	    "format-icons": {
	        "notification": "≤▒Ζτ",
	        "none": "ΎΔ│",
	        "dnd-notification": "ΎΘ╢",
	        "dnd-none": "≤░Γδ",
	        "inhibited-notification": "ΎΓλ",
	        "inhibited-none": "ΎΓλ",
	        "dnd-inhibited-notification": "ΎΘ╖",
	        "dnd-inhibited-none": "ΎΘ╖"
	    },
	    "return-type": "json",
	    "exec-if": "which swaync-client",
	    "exec": "swaync-client -swb",
	    "on-click": "sleep 0.1 && swaync-client -t -sw",
	    "on-click-right": "sleep 0.1 && swaync-client -d -sw",
	    "escape": true
	}
}
